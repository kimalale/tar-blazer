{
  "name": "cloudphone-ui",
  "version": "0.1.0",
  "private": true,
  "description": "React + TypeScript + Tailwind framework for CloudPhone widgets",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev":   "bun run --cwd apps/rps-duel dev",
    "build": "bun run --cwd apps/rps-duel build",
    "lint":  "bun run --cwd apps/rps-duel lint",
    "preview": "bun run --cwd apps/rps-duel preview"
  },
  "devDependencies": {
    "@types/react":       "^18.3.3",
    "@types/react-dom":   "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer":       "^10.4.19",
    "postcss":            "^8.4.38",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss":        "^3.4.4",
    "typescript":         "^5.4.5",
    "vite":               "^5.3.1"
  },
  "dependencies": {
    "react":     "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
